                ref fireAgain);

            string jsonBody;
            string client= Dts.Variables["User::Client"].Value.ToString();
            string crid = Dts.Variables["User::Code"].Value.ToString();
            string name = Dts.Variables["User::Name"].Value.ToString();
            string clientStatus = Dts.Variables["User::ClientStatus"].Value.ToString();

            string apiUrl = string.Concat(Dts.Variables["$Project::apiUrlCustomerRollup"].Value.ToString(), attributePathKey, "?companyId=", Dts.Variables["User::Client"].Value.ToString());



            if (isNew)
            {
                CreateCustomerRollupRecord(client, crid,name, clientStatus, out jsonBody);
                InsertUpdateQueue(apiUrl, "POST", "CR", "CR", jsonBody);
            }
            else
            {
                UpdateCustomerRollupRecord(client, crid, name, clientStatus, out jsonBody);
                InsertUpdateQueue(apiUrl, "PATCH", "CR", "CR", jsonBody);
            }

            Dts.TaskResult = (int)ScriptResults.Success;

 
		}

        private bool IsNew(string attributePathKey, out string responseCode, out string responseBody)
        {
            string username = Dts.Variables["$Project::u4ApiUserName"].Value.ToString();
            string password = Dts.Variables["$Project::u4ApiPassword"].Value.ToString();

            string url = "https://cc-dev.dt.com/Web_API_CCDEV3/v2/attribute-values/"
                         + attributePathKey
                         + "?companyId=DT";

            string credentials = Convert.ToBase64String(
                Encoding.ASCII.GetBytes(username + ":" + password));

            HttpWebRequest request = (HttpWebRequest)WebRequest.Create(url);
            request.Method = "GET";
            request.Headers["Authorization"] = "Basic " + credentials;
            request.Accept = "application/json";

            responseCode = "";
            responseBody = "";

            try
            {
                using (HttpWebResponse response = (HttpWebResponse)request.GetResponse())
                using (StreamReader reader = new StreamReader(response.GetResponseStream()))
                {
                    responseCode = ((int)response.StatusCode).ToString(); // 200
                    responseBody = reader.ReadToEnd();
                }

                return false; // exists -> not new
            }
            catch (WebException ex)
            {
                HttpWebResponse errorResponse = ex.Response as HttpWebResponse;
                if (errorResponse == null)
                {
                    throw;
                }

                responseCode = ((int)errorResponse.StatusCode).ToString();

                using (StreamReader reader = new StreamReader(errorResponse.GetResponseStream()))
                {
                    responseBody = reader.ReadToEnd();
                }

                if (errorResponse.StatusCode == HttpStatusCode.NotFound)
                {
                    return true; // 404 -> new
                }

                throw; // non-404 errors
            }
        }

        private void CreateCustomerRollupRecord(string Client, string attributePathKey, string Description, string ClientStatus, out string jsonBody)
        {
            // Adjust payload/endpoint to your API contract
            //string payload = Dts.Variables["User::CustomerRollupUpdates"].Value.ToString();
            //string url = "https://cc-dev.dt.com/Web_API_CCDEV3/v2/attribute-values?companyId=DT";

          

            jsonBody = CreateJsonBody(Client, attributePathKey,Description, ClientStatus);
        }

        private void UpdateCustomerRollupRecord(string Client, string attributePathKey, string Description, string ClientStatus, out string jsonBody)
        {
            // Adjust payload/endpoint to your API contract
            //string payload = Dts.Variables["User::CustomerRollupUpdates"].Value.ToString();
            //string url = "https://cc-dev.dt.com/Web_API_CCDEV3/v2/attribute-values/"
            //             + attributePathKey
            //             + "?companyId=DT";


            jsonBody = CreateUpdatePatchJsonBody(Client, attributePathKey, Description, ClientStatus);
        }
        private string CreateJsonBody(string Client, string CustomerRollupID, string CustomerRollupDescription, string ClientStatus)
        {
            JObject body = new JObject
            {
                ["attributeName"] = "CUSTROLLUP",
                ["attributeId"] = "OPCR",
                ["companyId"] = Client,
                ["description"] = CustomerRollupDescription,
                ["attributeValue"] = CustomerRollupID,
                ["periodFrom"] = "0",
                ["periodTo"] = "209999",
                ["status"] = ClientStatus,
                ["lastUpdated"] = new JObject
                {
                    ["updatedBy"] = "APIUSR"
                }
            };

            return body.ToString(Formatting.Indented);
        }
        private string CreateUpdatePatchJsonBody(string Client, string CustomerRollupID, string CustomerRollupDescription, string ClientStatus)
        {
            JArray patchOps = new JArray();

            if (!string.IsNullOrWhiteSpace(ClientStatus))
            {
                patchOps.Add(new JObject
                {
                    ["path"] = "status",
                    ["op"] = "Replace",
                    ["value"] = ClientStatus
                });
            }

            if (!string.IsNullOrWhiteSpace(CustomerRollupDescription))
            {
                patchOps.Add(new JObject
                {
                    ["path"] = "description",
                    ["op"] = "Replace",
                    ["value"] = CustomerRollupDescription
                });
            }

            return patchOps.ToString(Formatting.None);
        }


        private void InsertUpdateQueue(
            string apiUrl,
            string httpMethod,
            string objectName,
            string description,
            string jsonPayload)
        {
            // OLE DB connection manager name in SSIS
            string connectionManagerName = Dts.Variables["$Project::MDS_ConnectionString"].Value.ToString() ;

            // For OLE DB in Script Task, easiest pattern is to use the CM connection string
            //string connectionString = Dts.Connections[connectionManagerName].ConnectionString;
            string connectionString = Dts.Variables["$Project::MDS_ConnectionString"].Value.ToString();

            using (OleDbConnection conn = new OleDbConnection(connectionString))
            using (OleDbCommand cmd = new OleDbCommand("CC.p_InsertUpdateQueue", conn))
            {
                cmd.CommandType = CommandType.StoredProcedure;

                // IMPORTANT: OleDb parameters are positional (order matters)
                cmd.Parameters.Add("@ApiUrl", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(apiUrl) ? (object)DBNull.Value : apiUrl;

                cmd.Parameters.Add("@HttpMethod", OleDbType.VarChar, 50).Value =
                    string.IsNullOrWhiteSpace(httpMethod) ? (object)DBNull.Value : httpMethod;

                cmd.Parameters.Add("@Object", OleDbType.VarChar).Value =
