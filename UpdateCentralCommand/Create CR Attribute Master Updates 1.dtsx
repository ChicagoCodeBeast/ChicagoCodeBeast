                    string.IsNullOrWhiteSpace(description) ? (object)DBNull.Value : description;

                cmd.Parameters.Add("@JsonPayload", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(jsonPayload) ? (object)DBNull.Value : jsonPayload;

                conn.Open();
                cmd.ExecuteNonQuery();
            }
