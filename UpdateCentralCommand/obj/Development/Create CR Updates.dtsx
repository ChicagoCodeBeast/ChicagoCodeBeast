            string utilityFlag = Dts.Variables["User::UtilityFlag_Code"].Value.ToString();


            string responseCode;
            string responseBody;
            string originalMdsJson = BuildOriginalMdsJson(client, crid, name, clientStatus, code, tripStaxExtract, ibankExtract, utilityFlag, mdsLastChgDateTime);

            bool isNew = IsNew(attributePathKey, client, out responseCode, out responseBody);

            Dts.Variables["User::u4WebResponse"].Value =
                string.IsNullOrWhiteSpace(responseBody) ? "" : responseBody;


            string logMessageHeader = string.Concat("Client: " + Dts.Variables["User::Client"].Value.ToString() + " Code: " + Dts.Variables["User::Code"].Value.ToString(),
                 " | IsNew=" + isNew);

            string logMessageResponse = string.Concat("responseBody: " + responseBody);

            Dts.Events.FireInformation(
                3
                , logMessageHeader
                , logMessageResponse
                , ""
                , 0
                , ref fireAgain);

            string apiUrl = "";

            string contentType = "application/json-patch+json";


            if (isNew)
            {
                if (client == "CA")
                {
                    apiUrl = Dts.Variables["$Project::apiUrlCustomerRollupCA"].Value.ToString();

                }
                else
                {
                    apiUrl = Dts.Variables["$Project::apiUrlCustomerRollup"].Value.ToString();

                }

                CreateCustomerRollupRecord(client, crid,name, clientStatus, out jsonBody);
                InsertUpdateQueue(apiUrl, "POST", attributePathKey, "Customer Rollup", jsonBody, 1, "application/json", originalMdsJson);
            }
            else
            {
                if (client == "CA")
                {
                    apiUrl = string.Concat(Dts.Variables["$Project::apiUrlCustomerRollupCA"].Value.ToString(), attributePathKey, "?companyId=", Dts.Variables["User::Client"].Value.ToString());

                }
                else
                {
                    apiUrl = string.Concat(Dts.Variables["$Project::apiUrlCustomerRollup"].Value.ToString(), attributePathKey, "?companyId=", Dts.Variables["User::Client"].Value.ToString());
                }

                UpdateCustomerRollupRecord(client, crid, name, clientStatus, out jsonBody);
                InsertUpdateQueue(apiUrl, "PATCH", attributePathKey, "Customer Rollup", jsonBody,1, contentType, originalMdsJson);
            }

            // create relations 
            string IbankExtract_Code, TripStaxExtract_Code, UtilityFlag_Code;
            IbankExtract_Code = Dts.Variables["User::IbankExtract_Code"].Value.ToString();
            TripStaxExtract_Code = Dts.Variables["User::TripStaxExtract_Code"].Value.ToString();
            UtilityFlag_Code = Dts.Variables["User::UtilityFlag_Code"].Value.ToString();


            // Override the attributes for these clients 2026-04-16 Per Norma 
            if ((client == "DG") || (client == "CT"))
            {
                IbankExtract_Code = "N";
                TripStaxExtract_Code = "N";
                UtilityFlag_Code = "N";
            }

            string ibankJson = CreateCR_RelationPatchJsonBody("OP07", IbankExtract_Code);
            string tripstaxJson = CreateCR_RelationPatchJsonBody("OP06", TripStaxExtract_Code);
            string utiltiyFlagJson = CreateCR_RelationPatchJsonBody("ZAUT", UtilityFlag_Code);

            if (client == "CA")
            {
                apiUrl = string.Concat(Dts.Variables["$Project::apiUrlCustomerRollupCA"].Value.ToString(), attributePathKey, "?companyId=", Dts.Variables["User::Client"].Value.ToString());

            }
            else
            {
                apiUrl = string.Concat(Dts.Variables["$Project::apiUrlCustomerRollup"].Value.ToString(), attributePathKey, "?companyId=", Dts.Variables["User::Client"].Value.ToString());
            }

            InsertUpdateQueue(apiUrl, "PATCH", "Relation", "ibankJson", ibankJson, 2, contentType, originalMdsJson);
            InsertUpdateQueue(apiUrl, "PATCH", "Relation", "tripstaxJson", tripstaxJson, 2, contentType, originalMdsJson);
            InsertUpdateQueue(apiUrl, "PATCH", "Relation", "utiltiyFlagJson", utiltiyFlagJson, 2, contentType, originalMdsJson);

            Dts.Events.FireInformation(3, "Done Processing", "Client: " + Dts.Variables["User::Client"].Value.ToString() + " Customer Rollup ID:" + Dts.Variables["User::Code"].Value.ToString(), "", 0, ref fireAgain);

            Dts.TaskResult = (int)ScriptResults.Success;

 
		}

        private bool IsNew(string attributePathKey, string client, out string responseCode, out string responseBody)
        {
            string username = Dts.Variables["$Project::u4ApiUserName"].Value.ToString();
            string password = Dts.Variables["$Project::u4ApiPassword"].Value.ToString();

            //string url = "https://cc-dev.dt.com/Web_API_CCDEV3/v2/attribute-values/"
            //             + attributePathKey
            //             + "?companyId=" + client;

            string apiUrl = "";

            if (client == "CA")
            {
                apiUrl = Dts.Variables["$Project::apiUrlCustomerRollupCA"].Value.ToString() + attributePathKey
                         + "?companyId=" + client; 

            }
            else
            {
                apiUrl = Dts.Variables["$Project::apiUrlCustomerRollup"].Value.ToString() + attributePathKey
                         + "?companyId=" + client; ;

            }

            string credentials = Convert.ToBase64String(
                Encoding.ASCII.GetBytes(username + ":" + password));

            HttpWebRequest request = (HttpWebRequest)WebRequest.Create(apiUrl);
            request.Method = "GET";
            request.Headers["Authorization"] = "Basic " + credentials;
            request.Accept = "application/json";

            responseCode = "";
            responseBody = "";

            try
            {
                using (HttpWebResponse response = (HttpWebResponse)request.GetResponse())
                using (StreamReader reader = new StreamReader(response.GetResponseStream()))
                {
                    responseCode = ((int)response.StatusCode).ToString(); // 200
                    responseBody = reader.ReadToEnd();
                }

                return false; // exists -> not new
            }
            catch (WebException ex)
            {
                HttpWebResponse errorResponse = ex.Response as HttpWebResponse;
                if (errorResponse == null)
                {
                    throw;
                }

                responseCode = ((int)errorResponse.StatusCode).ToString();

                using (StreamReader reader = new StreamReader(errorResponse.GetResponseStream()))
                {
                    responseBody = reader.ReadToEnd();
                    ex.Data.Add("CCReturnJson", responseBody);
                }

                if (errorResponse.StatusCode == HttpStatusCode.NotFound)
                {
                    //StreamReader reader = new StreamReader(errorResponse.GetResponseStream());
                    //responseBody = reader.ReadToEnd();
                    return true; // 404 -> new
                }

                throw; // non-404 errors
            }
        }

        private void CreateCustomerRollupRecord(string Client, string attributePathKey, string Description, string ClientStatus, out string jsonBody)
        {

            jsonBody = CreateCR_Post_JsonBody(Client, attributePathKey,Description, ClientStatus);
        }

        private void UpdateCustomerRollupRecord(string Client, string attributePathKey, string Description, string ClientStatus, out string jsonBody)
        {
            // Adjust payload/endpoint to your API contract
            //string payload = Dts.Variables["User::CustomerRollupUpdates"].Value.ToString();
            //string url = "https://cc-dev.dt.com/Web_API_CCDEV3/v2/attribute-values/"
            //             + attributePathKey
            //             + "?companyId=DT";


            jsonBody = CreateCR_PatchJsonBody(Client, attributePathKey, Description, ClientStatus);
        }
        private string CreateCR_Post_JsonBody(string Client, string CustomerRollupID, string CustomerRollupDescription, string ClientStatus)
        {
            JObject body = new JObject
            {
                ["attributeName"] = "CUSTROLLUP",
                ["attributeId"] = "OPCR",
                ["companyId"] = Client,
                ["description"] = CustomerRollupDescription,
                ["attributeValue"] = CustomerRollupID,
                ["periodFrom"] = "0",
                ["periodTo"] = "209999",
                ["status"] = ClientStatus,
                ["lastUpdated"] = new JObject
                {
                    ["updatedBy"] = "APIUSR"
                }
            };

            return body.ToString(Formatting.Indented);
        }
        private string CreateCR_PatchJsonBody(string Client, string CustomerRollupID, string CustomerRollupDescription, string ClientStatus)
        {
            JArray patchOps = new JArray();

            if (!string.IsNullOrWhiteSpace(ClientStatus))
            {
                patchOps.Add(new JObject
                {
                    ["path"] = "status",
                    ["op"] = "Replace",
                    ["value"] = ClientStatus
                });
            }

            if (!string.IsNullOrWhiteSpace(CustomerRollupDescription))
            {
                patchOps.Add(new JObject
                {
                    ["path"] = "description",
                    ["op"] = "Replace",
                    ["value"] = CustomerRollupDescription
                });
            }

            return patchOps.ToString(Formatting.None);
        }
        public static string CreateCR_RelationPatchJsonBody(string relationId = "OP07", string relatedValue = "Y")
        {
        var payload = new JArray
            {
                new JObject
                {
                    ["path"] = "relatedValues",
                    ["op"] = "AddOrReplaceById",
                    ["value"] = new JObject
                    {
                        ["relationId"] = relationId,
                        ["relatedValue"] = relatedValue
                    }
                }
            };
            // Use Formatting.Indented if you want pretty JSON
            return payload.ToString(Formatting.Indented);
        }


        private string BuildOriginalMdsJson(
            string client,
            string crid,
            string name,
            string clientStatus,
            string code,
            string tripStaxExtract_code,
            string ibankExtract_code,
            string utilityFlag_code,
            string mdsLastChgDateTime)
        {
            var payload = new
            {
                client,
                crid,
                name,
                clientStatus,
                code,
                tripStaxExtract_code,
                ibankExtract_code,
                utilityFlag_code,
                mdsLastChgDateTime
            };

            return JsonConvert.SerializeObject(payload, Formatting.Indented);
        }

        private void InsertUpdateQueue(
            string apiUrl,
            string httpMethod,
            string objectName,
            string description,
            string jsonPayload,
            int batchID,
            string ContentType,
            string OriginalMdsJson)
        {
            // OLE DB connection manager name in SSIS
            string connectionManagerName = Dts.Variables["$Project::MDS_ConnectionString"].Value.ToString() ;

            // For OLE DB in Script Task, easiest pattern is to use the CM connection string
            //string connectionString = Dts.Connections[connectionManagerName].ConnectionString;
            string connectionString = Dts.Variables["$Project::MDS_ConnectionString"].Value.ToString();

            using (OleDbConnection conn = new OleDbConnection(connectionString))
            using (OleDbCommand cmd = new OleDbCommand("CC.p_InsertUpdateQueue", conn))
            {
                cmd.CommandType = CommandType.StoredProcedure;

                // IMPORTANT: OleDb parameters are positional (order matters)
                cmd.Parameters.Add("@ApiUrl", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(apiUrl) ? (object)DBNull.Value : apiUrl;

                cmd.Parameters.Add("@HttpMethod", OleDbType.VarChar, 50).Value =
                    string.IsNullOrWhiteSpace(httpMethod) ? (object)DBNull.Value : httpMethod;

                cmd.Parameters.Add("@ContentType", OleDbType.VarChar, 255).Value =
                    string.IsNullOrWhiteSpace(ContentType) ? (object)DBNull.Value : ContentType;

                cmd.Parameters.Add("@Object", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(objectName) ? (object)DBNull.Value : objectName;

                cmd.Parameters.Add("@Description", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(description) ? (object)DBNull.Value : description;

                cmd.Parameters.Add("@JsonPayload", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(jsonPayload) ? (object)DBNull.Value : jsonPayload;

                cmd.Parameters.Add("@batchID", OleDbType.Integer).Value = batchID;

                cmd.Parameters.Add("@OriginalMdsJson", OleDbType.VarChar).Value =
                    string.IsNullOrWhiteSpace(OriginalMdsJson) ? (object)DBNull.Value : OriginalMdsJson;

                conn.Open();
                cmd.ExecuteNonQuery();
            }
        }



        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
