    ISNULL(CONVERT(NVARCHAR(23), [UpdateDateTime], 121), '') AS [UpdateDateTime],
    ISNULL(CONVERT(NVARCHAR(23), [CreateDateTime], 121), '') AS [CreateDateTime]
FROM [MDS_Staging].[CC].[UpdateQueue]
WHERE [UpdateStatus] IS NULL
  order by BatchID, PK</property>
